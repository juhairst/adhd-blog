---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title='ADHD Flow Lab — Productivity Tips for ADHD Brains'>
  <section class='hero'>
    <h1>Productivity built for <span class='accent'>ADHD brains</span></h1>
    <p>Tools, planners, and strategies that work with your brain — not against it.</p>
  </section>
  <section class='posts'>
    <h2>Latest Posts</h2>
    <div class='post-grid'>
      {posts.map(post => (
        <a href={'/blog/' + post.slug} class='post-card'>
          <span class='post-tag'>{post.data.tags?.[0] ?? 'adhd'}</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <span class='read-more'>Read more →</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
